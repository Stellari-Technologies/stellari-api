# ============================================================================
# GITIGNORE - Files/Directories NOT Committed to Git
# ============================================================================
#
# YES, COMMIT THIS FILE!
#   .gitignore itself SHOULD be committed to git
#   It's a team convention telling everyone what not to commit
#   Without it, developers might accidentally commit secrets
#
# WHAT GOES IN GITIGNORE?
#   ✅ Environment secrets (.env, API keys)
#   ✅ Build artifacts (dist/, node_modules/)
#   ✅ IDE files (.vscode/, .idea/)
#   ✅ Dependencies (they're recreated via npm install)
#   ✅ Logs and temporary files
#   ✅ OS-specific files (.DS_Store on Mac)
#
# WHAT DOES NOT GO IN GITIGNORE?
#   ❌ Source code (.ts, .js files)
#   ❌ Configuration templates (.env.example - this is committed!)
#   ❌ package.json, package-lock.json (these are committed!)
#   ❌ README.md, documentation
#
# CONSEQUENCE OF NOT COMMITTING GITIGNORE:
#   Everyone has their own .gitignore → inconsistent team practices
#   Secrets accidentally committed by some developers
#   Build artifacts add noise to git history
#
# CONSEQUENCE OF COMMITTING A FILE THAT SHOULD BE IGNORED:
#   Secrets exposed to everyone on the team
#   Build artifacts bloat the repository
#   Updates to your machine affect version control
#
# ============================================================================

# NODE & NPM
node_modules/
package-lock.json.bak
.npmrc
*.tgz

# ENVIRONMENT & SECRETS (Never commit!)
.env
.env.local
.env.*.local
.env.production.local

# BUILD OUTPUT (Recreated with npm run build)
dist/
build/
coverage/
*.tsbuildinfo

# LOGS
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# TYPESCRIPT
.tsbuildinfo
dist

# IDE & EDITOR FILES
.vscode/
.idea/
*.swp
*.swo
*.iml
.DS_Store
.project
.classpath
.c9/
.settings/
*.sublime-workspace

# ESLINT & LINTING
.eslintcache
.stylelintcache

# TESTING
coverage/
.nyc_output/
.jest_cache/

# DEVELOPMENT TOOLS
.node_repl_history
.npm
.yarn-integrity
.pnp
.pnp.js

# OS FILES
.DS_Store
Thumbs.db

# TEMPORARY & CACHE
.cache/
.parcel-cache
.next
out
.nuxt
.vitepress/dist
.svelte-kit/
.docusaurus
.temp

# SERVERLESS
.serverless/

# FIREBASE
.firebase/

# VSCODE TEST
.vscode-test

# Docker (optional - comment out if developing with Docker)
# docker-compose.override.yml

# Keep .env.example - it's a template!
!.env.example
!.gitignore
!.yarn/sdks
!.yarn/versions

# Vite logs files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
