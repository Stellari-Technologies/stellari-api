# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
#
# WHAT IS THIS?
# - Template showing all environment variables your app needs
# - Copy to .env and fill with your actual values (never commit .env to git!)
# - Used in development and local Docker testing
#
# SECURITY RULES:
# ❌ NEVER commit .env files to git (they contain secrets!)
# ❌ NEVER store secrets in Docker images
# ✅ Use .env only for LOCAL development
# ✅ Use AWS Secrets Manager for production deployments
# ✅ Use CI/CD to inject secrets at deployment time
#
# HOW TO USE:
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Fill in your actual values:
#    PORT=3000
#    DB_HOST=localhost
#    DB_PASSWORD=your_actual_password
#
# 3. Start the app:
#    npm run dev
#
# LOCAL vs PRODUCTION SECRETS:
#
# Development (Local):
#   - Use .env file with dummy/test credentials
#   - OK to be less secure (local testing)
#   - Example: DB_PASSWORD=postgres (default Docker postgres)
#
# Production (AWS):
#   - Use AWS Secrets Manager
#   - Accessed via IAM role (not via .env)
#   - Example: ECS task pulls from Secrets Manager automatically
#   - Never use .env in production deployments
#
# AWS SECRETS MANAGER PATTERN:
#
# In CodePipeline → CodeBuild → ECS:
#   1. Create secret in AWS Secrets Manager:
#      aws secretsmanager create-secret --name stellari/prod/db-password --secret-string "actual-password"
#
#   2. Grant ECS task role permission to read secret
#
#   3. ECS task pulls secret and injects as env var
#
#   4. Container started with secure env vars (no .env file)
#
# See AWS documentation:
#   https://docs.aws.amazon.com/secretsmanager/latest/userguide/
#   https://docs.aws.amazon.com/AmazonECS/latest/developerguide/task_execution_IAM_role.html
#
# ============================================================================

# SERVER
PORT=3000
NODE_ENV=development

# DATABASE - Local Development Only
# For production, use AWS RDS endpoint and Secrets Manager for password
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stellari_app

# AWS - For CodePipeline Deployment
# Local: Not needed for local development
# Production: Use IAM roles instead of hardcoded keys
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# LOGGING
LOG_LEVEL=info
# Options: error, warn, info, debug
# Set to debug to see detailed logs in development

