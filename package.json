{
  "name": "stellari-platform-api",
  "version": "1.0.0",
  "description": "Stellari Platform API - TypeScript Express Backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "typeorm": "typeorm",
    "migration:generate": "typeorm migration:generate",
    "migration:run": "typeorm migration:run",
    "migration:revert": "typeorm migration:revert",
    "seed": "ts-node src/seeds/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "aws-sdk": "^2.1500.0",
    "dotenv": "^16.3.1",
    "typeorm": "^0.3.16",
    "pg": "^8.11.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.2",
    "winston": "^3.10.0",
    "cors": "^2.8.5",
    "helmet": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/cors": "^2.8.13",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "jest": "^29.6.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  }
}
