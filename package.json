{
  "name": "stellari-platform-api",
  "version": "1.0.0",
  "description": "Stellari Platform API - TypeScript Express Backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "typeorm": "typeorm",
    "migration:generate": "typeorm migration:generate",
